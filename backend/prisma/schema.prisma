generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  ZAPATO
  BOLSA
}

model Product {
  id        Int         @id @default(autoincrement())
  nombre    String
  color     String
  talla     String?
  tipo      ProductType
  precio    Float
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("products")
}
